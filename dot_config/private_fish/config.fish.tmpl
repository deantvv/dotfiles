{{ if eq .chezmoi.os "darwin" -}}
function fish_greeting
    echo
    echo -e (uname -rs | awk '{print " \\\\e[1mOS: \\\\e[0;32m"$0"\\\\e[0m"}')
    echo -e (uptime | sed 's/^.*up \([^,]*\),.*/\1/' | awk '{print " \\\\e[1mUptime: \\\\e[0;32m"$0"\\\\e[0m"}')
    echo -e (uname -n | awk '{print " \\\\e[1mHostname: \\\\e[0;32m"$0"\\\\e[0m"}')

    if command -q ifconfig
        echo -e " \\e[1mNetwork:\\e[0m"
        echo
        echo -ne (\
            ifconfig | \
            awk '
                /^[a-z][^ ]*:/ { iface=$1; gsub(/:$/, "", iface) }
                /inet / && iface != "lo0" {
                    color = "\\\\e[36m"
                    if (iface ~ /^en/) color = "\\\\e[39m"
                    if (iface ~ /^wl/) color = "\\\\e[35m"
                    printf "\t%s%-12s\\\\e[0m %s\\\n\n", color, iface, $2
                }' \
        )
        echo
    end
end
{{ else -}}
function fish_greeting
    echo
    echo -e (uname -ro | awk '{print " \\\\e[1mOS: \\\\e[0;32m"$0"\\\\e[0m"}')
    echo -e (uptime | sed 's/^.*up  *\([^,]*\),.*/\1/' | awk '{print " \\\\e[1mUptime: \\\\e[0;32m"$0"\\\\e[0m"}')
    echo -e (uname -n | awk '{print " \\\\e[1mHostname: \\\\e[0;32m"$0"\\\\e[0m"}')

    if command -q ip
        echo -e " \\e[1mNetwork:\\e[0m"
        echo
        echo -ne (\
            ip addr show up scope global | \
                grep -E ': <|inet' | \
                sed \
                    -e 's/^[[:digit:]]\+: //' \
                    -e 's/: <.*//' \
                    -e 's/.*inet[[:digit:]]* //' \
                    -e 's/\/.*//' | \
                awk 'BEGIN {i=""} /\.|:/ {print i" "$0"\\\n"; next} // {i = $0}' | \
                sort | \
                column -t -R1 | \
                sed 's/ \([^ ]\+\)$/ \\\e[4m\1/' | \
                sed 's/m\(\(10\.\|172\.\(1[6-9]\|2[0-9]\|3[01]\)\|192\.168\.\).*\)/m\\\e[24m\1/' | \
                sed 's/^\( *[^ ]\+\)/\\\e[36m\1/' | \
                sed 's/\(\(en\|em\|eth\)[^ ]* .*\)/\\\e[39m\1/' | \
                sed 's/\(wl[^ ]* .*\)/\\\e[35m\1/' | \
                sed 's/\(ww[^ ]* .*\).*/\\\e[33m\1/' | \
                sed 's/$/\\\e[0m/' | \
                sed 's/^/\t/' \
            )
        echo
    end
end
{{ end -}}

{{ if has .chezmoi.hostname (list "Mac" "win") -}}
if status --is-interactive
	switch $TERM
		case 'linux'
			:
		case '*'
			if ! set -q TMUX; and ! set -q NO_TMUX; and test "$TERM_PROGRAM" != "vscode"
				exec tmux set-option -g default-shell (which fish) ';' new-session -A -s main
			end
	end
end

{{ end -}}
mise activate fish | source
